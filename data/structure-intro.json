    {
      "id": "TQB-STR-0001",
      "section": "Structure",
      "type": "Sentence Completion",
      "skill": "Subject-Verb Agreement",
      "subskill": "Each + Singular Verb",
      "difficulty": 2,
      "estimatedTime": 40,
      "academicTopic": "Education",
      "question": "Each of the students _____ required to submit a final research paper.",
      "options": [
        {
          "key": "A",
          "text": "are"
        },
        {
          "key": "B",
          "text": "is"
        },
        {
          "key": "C",
          "text": "were"
        },
        {
          "key": "D",
          "text": "have been"
        }
      ],
      "correctKey": "B",
      "correctAnswer": "is",
      "explanation": "'Each' is singular, so it requires the singular verb 'is.'",
      "commonMistake": "Making the verb agree with the plural noun 'students' instead of 'each.'",
      "learningObjective": "Identify singular indefinite pronouns as sentence subjects.",
      "tags": [
        "subject_verb_agreement",
        "each",
        "singular_subject"
      ]
    },
    {
      "id": "TQB-STR-0004",
      "section": "Structure",
      "type": "Sentence Completion",
      "skill": "Subject-Verb Agreement",
      "subskill": "Prepositional Phrase Interruption",
      "difficulty": 3,
      "estimatedTime": 45,
      "academicTopic": "Biology",
      "question": "The behavior of several marine species _____ affected by changes in water temperature.",
      "options": [
        {
          "key": "A",
          "text": "are"
        },
        {
          "key": "B",
          "text": "were"
        },
        {
          "key": "C",
          "text": "is"
        },
        {
          "key": "D",
          "text": "have been"
        }
      ],
      "correctKey": "C",
      "correctAnswer": "is",
      "explanation": "The subject is 'behavior,' not 'species,' so the singular verb 'is' is required.",
      "commonMistake": "Making the verb agree with the noun closest to it.",
      "learningObjective": "Identify the true subject when prepositional phrases intervene.",
      "tags": [
        "subject_verb_agreement",
        "prepositional_phrases",
        "true_subject"
      ]
    },
    {
