        {
          "key": "B",
          "text": "be"
        },
        {
          "key": "C",
          "text": "was"
        },
        {
          "key": "D",
          "text": "being"
        }
      ],
      "correctKey": "B",
      "correctAnswer": "be",
      "explanation": "After expressions such as 'it is essential that,' formal English uses the subjunctive base form.",
